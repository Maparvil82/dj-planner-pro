{
  "expo": {
    "name": "DJ Planner PRO",
    "slug": "dj-planner-pro",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "djplannerpro",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.djplannerpro.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "DJ Planner Pro necesita acceso a la cámara para que puedas tomar fotos de tus carteles y avatares.",
        "NSPhotoLibraryUsageDescription": "DJ Planner Pro necesita acceso a tu galería para que puedas seleccionar fotos de tus carteles y avatares."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.djplannerpro.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "03382504-5cac-4497-a9cb-6f13cfee2e36"
      }
    }
  }
}